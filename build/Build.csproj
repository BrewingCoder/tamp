<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Tamp's self-hosted build script. Drives the project's own
    restore / build / test / pack flow via the framework being
    built. Single-target net10 (only place we don't multi-target —
    the build script just runs on whichever .NET 10 SDK is local).
    IsPackable=false; the build script is never published.

    ProjectReferences (not PackageReferences) wire to the in-tree
    Tamp.Core and Tamp.NetCli.V10. That means a change to either
    flows through to the next `dotnet run` of this project
    without a republish round-trip.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Tamp.Build</RootNamespace>
    <AssemblyName>Tamp.Build</AssemblyName>
    <IsPackable>false</IsPackable>
    <!-- Build scripts don't need most of the inherited package metadata. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\src\Tamp.Core\Tamp.Core.csproj" />
    <ProjectReference Include="..\src\Tamp.NetCli.V10\Tamp.NetCli.V10.csproj" />
    <ProjectReference Include="..\src\Tamp.DotNetCoverage.V18\Tamp.DotNetCoverage.V18.csproj" />

    <!-- Wave 1 security chain: dogfooded on every build that opts into
         the Security target (TAM-245). -->
    <ProjectReference Include="..\src\Tamp.Sarif\Tamp.Sarif.csproj" />
    <ProjectReference Include="..\src\Tamp.Sbom\Tamp.Sbom.csproj" />
    <ProjectReference Include="..\src\Tamp.CycloneDx.V6\Tamp.CycloneDx.V6.csproj" />
    <ProjectReference Include="..\src\Tamp.OpenGrep.V1\Tamp.OpenGrep.V1.csproj" />
    <ProjectReference Include="..\src\Tamp.DependencyTrack.V1\Tamp.DependencyTrack.V1.csproj" />
    <ProjectReference Include="..\src\Tamp.DefectDojo.V2\Tamp.DefectDojo.V2.csproj" />
    <ProjectReference Include="..\src\Tamp.OsvScanner.V2\Tamp.OsvScanner.V2.csproj" />
    <ProjectReference Include="..\src\Tamp.Trivy\Tamp.Trivy.csproj" />

    <!--
      Cross-repo PackageReference: Tamp.SonarScanner.V10 ships from
      tamp-build/tamp-sonar. Pinned to 0.1.0, the first non-placeholder
      release from the satellite dogfood pipeline. CPM-enabled via
      Directory.Packages.props.
    -->
    <PackageReference Include="Tamp.SonarScanner.V10" />
  </ItemGroup>

</Project>
