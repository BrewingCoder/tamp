<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>Tamp.CycloneDx.V6</RootNamespace>
    <AssemblyName>Tamp.CycloneDx.V6</AssemblyName>
  </PropertyGroup>

  <PropertyGroup Label="Package">
    <PackageId>Tamp.CycloneDx.V6</PackageId>
    <Description>Tamp CommandPlan wrapper for the `dotnet-CycloneDX` global tool (6.x) — generates CycloneDX SBOMs from .NET projects and solutions. Pinned to 6.x: the 5→6 boundary renamed --json to --output-format Json, dropped --include-xml / --exclude-transitive / --set-serial-number, and the spec version default shifted to 1.7. Defaults to JSON output because the Wave 1 chain (Dependency-Track) consumes JSON.</Description>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Tamp.Core\Tamp.Core.csproj" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>

</Project>
