<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>Tamp.OpenGrep</RootNamespace>
    <AssemblyName>Tamp.OpenGrep</AssemblyName>
  </PropertyGroup>

  <PropertyGroup Label="Package">
    <PackageId>Tamp.OpenGrep</PackageId>
    <Description>Tamp CommandPlan wrapper for the `opengrep` CLI. Pattern-based SAST scanner forked from Semgrep with cleaner licensing (multi-vendor governance, no Pro paywall). Defaults to SARIF output because the Wave 1 chain (DefectDojo) consumes SARIF. Unpinned name (no .V{N} suffix) per ADR 0002 — OpenGrep was forked at 1.x with no prior 0.x to break compat with, and the project is committed to surface stability; if a future major breaks the wrapper this will be re-pinned as Tamp.OpenGrep.VN.</Description>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Tamp.Core\Tamp.Core.csproj" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>

</Project>
