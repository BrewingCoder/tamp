<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>Tamp.DependencyTrack.V1</RootNamespace>
    <AssemblyName>Tamp.DependencyTrack.V1</AssemblyName>
  </PropertyGroup>

  <PropertyGroup Label="Package">
    <PackageId>Tamp.DependencyTrack.V1</PackageId>
    <Description>Tamp REST client for OWASP Dependency-Track v4.x (API v1). Upload CycloneDX BOMs, poll the asynchronous analysis to completion, export findings in raw FPF JSON for downstream passthrough to DefectDojo. Uses Tamp.Sbom for typed BOM input and Tamp.Core's Polling.Until for the analysis-complete wait.</Description>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Tamp.Core\Tamp.Core.csproj" />
    <ProjectReference Include="..\Tamp.Sbom\Tamp.Sbom.csproj" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>

</Project>
