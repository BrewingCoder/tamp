<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>Tamp.OsvScanner.V2</RootNamespace>
    <AssemblyName>Tamp.OsvScanner.V2</AssemblyName>
  </PropertyGroup>

  <PropertyGroup Label="Package">
    <PackageId>Tamp.OsvScanner.V2</PackageId>
    <Description>Tamp CommandPlan wrapper for Google's `osv-scanner` (2.x). Cross-ecosystem SCA: reads a CycloneDX SBOM or per-language lockfiles, queries OSV.dev (npm, PyPI, Cargo, Go, Maven, NuGet, Packagist, Pub, …), emits SARIF or CycloneDX 1.5 with inline VEX. Pinned to 2.x — the 1→2 boundary restructured the CLI around subcommands and deprecated the original --sbom-only invocation form.</Description>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Tamp.Core\Tamp.Core.csproj" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>

</Project>
